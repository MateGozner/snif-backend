{
  "ConnectionStrings": {
    "DefaultConnection": "${DB_CONNECTION_STRING}"
  },
  "Jwt": {
    "Key": "${JWT_KEY}",
    "Issuer": "${JWT_ISSUER}",
    "Audience": "${JWT_AUDIENCE}"
  },
  "WebRoot": {
    "Path": "wwwroot"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "RabbitMQ": {
    "Enabled": false,
    "HostName": "${RABBITMQ_HOST}",
    "Port": 5672,
    "UserName": "${RABBITMQ_USER}",
    "Password": "${RABBITMQ_PASSWORD}",
    "VirtualHost": "/",
    "Exchanges": {
      "Watchlist": "pet.watchlist",
      "Matches": "pet.matches"
    },
    "WebSocketPort": 15674
  },
  "AllowedHosts": "*",
  "Swagger": {
    "Enabled": true
  },
  "Cors": {
    "AllowedOrigins": [
      "${FRONTEND_URL}"
    ]
  }
}
